---
---
<header class="sticky top-0 z-50" style="background: oklch(0.14 0.038 36 / 0.92); border-bottom: 1px solid oklch(0.28 0.030 38); backdrop-filter: blur(16px) saturate(1.1);">
  <nav class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-10 h-16 flex items-center justify-between">
    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- Small cup icon -->
      <svg class="w-5 h-5 flex-shrink-0" style="color: oklch(0.72 0.12 52);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
      </svg>
      <span class="font-display font-bold text-lg tracking-tight" style="color: oklch(0.96 0.015 72);">Brewnest</span>
    </a>

    <!-- Nav links -->
    <div class="flex items-center gap-7">
      <a href="#how-it-works"
         class="hidden sm:block text-sm font-medium transition-colors duration-150"
         style="color: oklch(0.65 0.015 65); font-family: var(--font-body);"
         onmouseover="this.style.color='oklch(0.80 0.10 55)'"
         onmouseout="this.style.color='oklch(0.65 0.015 65)'">
        How it works
      </a>
      <a href="#join"
         class="text-sm font-semibold px-5 py-2 rounded-sm transition-all duration-150 hover:opacity-90"
         style="background: oklch(0.62 0.12 52); color: oklch(0.12 0.035 35); font-family: var(--font-body);">
        Start my box
      </a>
    </div>
  </nav>
</header>
