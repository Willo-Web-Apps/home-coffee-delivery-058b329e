---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Brewnest — Your Coffee Shop Ritual, Delivered Home", description = "Brewnest delivers freshly roasted specialty coffee, barista recipes, and café-style guides so every morning at home feels like your favorite café." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Brewnest",
      "description": "At-home coffee shop membership delivering freshly roasted specialty coffee, barista guides, and seasonal café recipes.",
      "url": "https://home-coffee-delivery.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased" style="background: oklch(0.985 0.006 72); color: oklch(0.18 0.040 38); font-family: var(--font-body);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
